# Docker Live Visualizer Configuration
# Copy this file to .env and fill in your values

# The port on the host where the web app will be accessible
APP_PORT=9100

# The title displayed in the web UI
APP_TITLE=Docker Live Visualizer

# Optional: API Key for endpoint protection (leave empty to disable)
# If set, client requests must send Header "Authorization: Bearer <API_KEY>"
API_KEY=

# Optional: Log level (debug, info, warning, error)
LOG_LEVEL=info
